<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox spacing="0"
      stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.music_catalogue.controller.MusicController">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <Label text="♪  My Favorite Music Catalogue" styleClass="app-title" />
    </HBox>

    <VBox spacing="0"><padding><Insets top="18"/></padding></VBox>

    <!-- Form Card -->
    <VBox styleClass="form-panel" spacing="14">

        <Label text="SONG DETAILS" styleClass="section-label" />

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="56" maxWidth="56" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40" />
                <ColumnConstraints minWidth="56" maxWidth="56" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40" />
            </columnConstraints>

            <!-- Row 0: Title + Artist -->
            <Label text="Title"  styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.valignment="CENTER" />
            <TextField fx:id="titleField"  promptText="Song title"
                       maxWidth="1.7976931348623157E308"
                       GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" />
            <Label text="Artist" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="2" GridPane.valignment="CENTER" />
            <TextField fx:id="artistField" promptText="Artist / Band"
                       maxWidth="1.7976931348623157E308"
                       GridPane.rowIndex="0" GridPane.columnIndex="3" GridPane.hgrow="ALWAYS" />

            <!-- Row 1: Album + Year -->
            <Label text="Album"  styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="CENTER" />
            <TextField fx:id="albumField"  promptText="Album"
                       maxWidth="1.7976931348623157E308"
                       GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" />
            <Label text="Year"   styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="2" GridPane.valignment="CENTER" />
            <TextField fx:id="yearField"   promptText="e.g. 2024"
                       maxWidth="1.7976931348623157E308"
                       GridPane.rowIndex="1" GridPane.columnIndex="3" GridPane.hgrow="ALWAYS" />

            <!-- Row 2: Genre + Rating -->
            <Label text="Genre"  styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.valignment="CENTER" />
            <ComboBox fx:id="genreComboBox" promptText="Select genre"
                      maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="2" GridPane.columnIndex="1" />
            <Label text="Rating" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="2" GridPane.valignment="CENTER" />
            <ComboBox fx:id="ratingComboBox" promptText="★ Rating"
                      maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="2" GridPane.columnIndex="3" />

            <!-- Row 3: Notes full width -->
            <Label text="Notes"  styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.valignment="TOP">
                <padding><Insets top="10"/></padding>
            </Label>
            <TextArea fx:id="notesArea" promptText="Personal notes…"
                      prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="3" GridPane.columnIndex="1" />
        </GridPane>

        <!-- Action bar -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="4"/></padding>
            <Label text="ID" styleClass="field-label" />
            <TextField fx:id="idField" editable="false" promptText="Auto"
                       styleClass="text-field, id-field"
                       prefWidth="64" maxWidth="64" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Add Song" onAction="#handleAdd"    styleClass="btn-primary" />
            <Button text="Update"   onAction="#handleUpdate" styleClass="btn-secondary" />
            <Button text="Delete"   onAction="#handleDelete" styleClass="btn-danger" />
            <Button text="Clear"    onAction="#handleClear"  styleClass="btn-secondary" />
        </HBox>

    </VBox>

    <VBox spacing="0"><padding><Insets top="16"/></padding></VBox>

    <!-- Table -->
    <TableView fx:id="songTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn"     text="ID"      prefWidth="55"  />
            <TableColumn fx:id="titleColumn"  text="Title"   prefWidth="210" />
            <TableColumn fx:id="artistColumn" text="Artist"  prefWidth="165" />
            <TableColumn fx:id="albumColumn"  text="Album"   prefWidth="165" />
            <TableColumn fx:id="genreColumn"  text="Genre"   prefWidth="95"  />
            <TableColumn fx:id="yearColumn"   text="Year"    prefWidth="68"  />
            <TableColumn fx:id="ratingColumn" text="★"       prefWidth="52"  />
            <TableColumn fx:id="notesColumn"  text="Notes"   prefWidth="240" />
        </columns>
    </TableView>

    <VBox spacing="0"><padding><Insets top="12"/></padding></VBox>

    <!-- Pagination -->
    <Pagination fx:id="songPagination" pageCount="1" maxPageIndicatorCount="7" />

</VBox>
